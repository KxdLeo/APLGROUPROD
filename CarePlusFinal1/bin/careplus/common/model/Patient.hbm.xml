<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="careplus.common.model.Patient" table="patients">
        <id name="id" column="patient_id" type="string" />
        <property name="firstName" column="first_name" type="string" />
        <property name="lastName" column="last_name" type="string" />
        <property name="contactNumber" column="contact_number" type="string" />
        <property name="password" column="password" type="string" />
        <property name="medicalHistory" column="medical_history" type="string" />
    </class>
</hibernate-mapping>
